{
    "browser": {
        "chatInputSelector": "textarea, div[contenteditable=\"true\"]",
        "assistantOutputSelector": ".markdown.prose",
        "sendButtonSelector": "button[data-testid=\"send-button\"]",
        "enabledSendButtonSelector": "button[data-testid=\"send-button\"]:not([disabled])",
        "remoteDebuggingUrl": "http://127.0.0.1:9222",
        "chatgptUrl": "https://chatgpt.com/c/69fa9fc7-aa40-83a9-8244-b30a4b7c3cd5",
        "existingPageUrlIncludes": ["chatgpt.com", "chat.openai.com"],
        "inputTimeoutMs": 60000,
        "typeDelayMs": 5,
        "outputPollIntervalMs": 300,
        "initialStateDelaySeconds": 3,
        "chromeConnectErrorMessage": "Failed to connect to Chrome. Start Chrome with: chrome.exe --remote-debugging-port=9222 --user-data-dir=\"C:\\chrome-debug-profile\""
    },

    "audit": {
        "validTopLevelFields": ["speech", "emotion", "intensity", "actions", "requests"],
        "validEmotions": [
            "neutral",
            "happy",
            "calm",
            "sad",
            "angry",
            "surprised",
            "fear",
            "thinking"
        ],
        "intensityMin": 0.0,
        "intensityMax": 1.0
    },

    "actions": {
        "tear": {
            "endpointUrl": "http://kokomi.local:5000/motor/command",
            "speedMin": 0,
            "speedMax": 255,
            "durationMin": 0,
            "durationMax": 255
        },
        "ledChange": {
            "endpointUrl": "http://kokomi.local:5000/led/command",
            "colorPattern": "^#[0-9A-Fa-f]{6}$"
        }
    },

    "sensors": {
        "bme280Url": "http://kokomi.local:5000/bme280/sensor_data",
        "brightnessUrl": "http://192.168.0.149:5000/cds/sensor_data",
        "bme280PollIntervalMs": 1000,
        "brightnessPollIntervalMs": 1000,
        "brightnessResponseFields": ["brightness", "cds"],
        "brightnessDarkThreshold": 40,
        "units": {
            "temperature": "celsius",
            "humidity": "percent",
            "pressure": "hpa",
            "brightness": "raw"
        }
    },

    "touch": {
        "source": "touch",
        "startedType": "touch_started",
        "endedType": "touch_ended",
        "sensorBindings": {
            "touch_01": "head",
            "touch_02": "hand",
            "touch_03": "shoulder"
        },
        "startedAction": "petting_started",
        "endedAction": "petting_ended"
    },

    "tts": {
        "enabled": true,
        "baseUrl": "https://api.elevenlabs.io/v1/text-to-speech",
        "defaultVoiceId": "JgWCVquTJEvtfo5gWQkx",
        "defaultModelId": "eleven_v3",
        "defaultOutputFormat": "mp3_44100_128",
        "playerCommand": "ffplay",
        "playerArgs": [
            "-nodisp",
            "-autoexit",
            "-loglevel",
            "quiet",
            "-"
        ]
    },

    "vision": {
        "snapshotUrl": "http://localhost:5000/snapshot",
        "generateUrl": "http://localhost:11434/api/generate",
        "model": "llava",
        "stream": false,
        "defaultQuery": "describe the scene",
        "task": "describe_scene",
        "maxWords": 50,
        "instructionTemplate": "Describe the scene in English in 1-2 sentences, maximum {maxWords} words. Focus only on important objects, people, and actions. Do not repeat details.\n"
    },

    "routes": {
        "yoloEvent": "/yolo_event",
        "touchSensorInput": "/touch_sensor_input",
        "userInput": "/user_input"
    },

    "events": {
        "personAppeared": {
            "source": "deepsort",
            "type": "person_appeared",
            "message": "A person has appeared."
        }
    },

    "server": {
        "port": 3000
    }
}
